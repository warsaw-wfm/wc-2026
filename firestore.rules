rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────
    // Anyone can read (leaderboard). Anyone can write EXCEPT escalating to admin.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.resource.data.get('isAdmin', false) == false
                    && request.resource.data.get('isAdminAccount', false) == false;
      allow update: if request.resource.data.get('isAdmin', false) == false
                    && request.resource.data.get('isAdminAccount', false) == false;
    }

    // ── Predictions ──────────────────────────────────────────────────────
    match /predictions/{predId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Matches — readable by all, writable by any client ──────────────────
    match /matches/{matchId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Config — read-only for clients ───────────────────────────────────
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
