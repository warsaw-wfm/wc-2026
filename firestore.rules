rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────
    // Anyone can read users (leaderboard)
    // Only the user themselves can write their own doc
    match /users/{userId} {
      allow read: if true;
      allow create: if request.resource.data.isAdminAccount != true
                    && request.resource.data.isAdmin != true;
      allow update: if request.auth == null
                    // PIN-based app: allow update only to safe fields
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['totalPoints', 'exactScores', 'correctResults',
                                   'championPick', 'goldenBootPick', 'nickname']);
    }

    // ── Predictions ──────────────────────────────────────────────────────
    // Anyone can read predictions (compare picks)
    // Anyone can write their own prediction (PIN-auth, no Firebase Auth)
    match /predictions/{predId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Matches (results) ────────────────────────────────────────────────
    // Read-only for clients — written only by GitHub Actions (service account)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Config (lastSync etc.) ───────────────────────────────────────────
    // Read-only for clients
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
